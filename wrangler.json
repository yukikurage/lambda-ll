{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lambda-ll",
  "main": ".open-next/assets/cloudflare-bundle.mjs",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "NEXT_CACHE_WORKERS_KV",
      "id": "YOUR_KV_NAMESPACE_ID"
    }
  ]
}